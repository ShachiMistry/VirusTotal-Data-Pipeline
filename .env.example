# VirusTotal API Key — get yours at https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your_virustotal_api_key_here

# Database connection (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./virustotal.db
# For AWS RDS PostgreSQL use:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/virustotal

# Redis cache (leave blank to use in-memory fallback)
REDIS_URL=
# For AWS ElastiCache use:
# REDIS_URL=redis://your-elasticache-cluster.amazonaws.com:6379

# Cache TTL in seconds (default 1 hour)
CACHE_TTL_SECONDS=3600

# Rate limiter — VirusTotal free tier allows 4 requests/min
VT_RATE_LIMIT_RPM=4

# App environment
APP_ENV=production
LOG_LEVEL=INFO

# CORS — in production, set this to your frontend ALB URL
# CORS_ORIGINS=http://your-alb-url.us-east-1.elb.amazonaws.com
CORS_ORIGINS=*
